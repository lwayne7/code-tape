{
  "name": "code-tape",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "prepare": "npm run hooks:install",
    "hooks:install": "node scripts/workflows/install-hooks.mjs",
    "agent:bootstrap": "node scripts/workflows/contract-check.mjs bootstrap",
    "contract:local": "node scripts/workflows/contract-check.mjs local",
    "contract:check": "node scripts/workflows/contract-check.mjs check",
    "contract:gitnexus": "node scripts/workflows/contract-check.mjs gitnexus",
    "quality:predev": "npm run hooks:install && npm run contract:local",
    "quality:precommit": "npm test && npm run build:schema && npm run lint:web && npm run test:schema && npm run test:api && npm run test:web && npm run build",
    "quality:ci": "npm test && npm run build:schema && npm run lint:web && npm run test:schema && npm run test:api && npm run test:web && npm run build && npm run e2e:web",
    "quality:local": "npm run contract:local && npm run quality:ci",
    "subtitle:dataset:validate": "node scripts/subtitle-llm/validate-dataset.mjs ml/subtitle-postprocessor/data/seed_examples.jsonl",
    "subtitle:curate": "node scripts/subtitle-llm/augment-corpus.mjs",
    "subtitle:distill": "node scripts/subtitle-llm/distill-corpus.mjs --seed ml/subtitle-postprocessor/data/seed_examples.jsonl --out ml/subtitle-postprocessor/data/generated/distilled.jsonl",
    "subtitle:evaluate": "node scripts/subtitle-llm/evaluate-corpus.mjs ml/subtitle-postprocessor/data/generated/distilled.jsonl",
    "subtitle:postprocess:evaluate": "node scripts/subtitle-llm/evaluate-postprocessor.mjs scripts/tests/fixtures/subtitle-postprocessor-eval.json",
    "subtitle:postprocess:runtime-benchmark": "node scripts/subtitle-llm/run-runtime-benchmark.mjs",
    "subtitle:train": "python3 ml/subtitle-postprocessor/train_lora.py --train-jsonl ml/subtitle-postprocessor/data/generated/distilled.jsonl",
    "subtitle:train:help": "python3 ml/subtitle-postprocessor/train_lora.py --help",
    "dev": "npm run dev -w apps/web -- --host 127.0.0.1",
    "dev:web": "npm run dev -w apps/web -- --host 127.0.0.1",
    "build": "npm run build:schema && npm run build:api && npm run build -w apps/web",
    "build:schema": "npm run build -w @code-tape/recording-schema",
    "build:api": "npm run build -w apps/api",
    "preview": "npm run preview -w apps/web",
    "test:web": "npm run test -w apps/web",
    "test:schema": "npm run test -w @code-tape/recording-schema",
    "test:api": "npm run test -w apps/api",
    "lint:web": "npm run lint -w apps/web",
    "e2e:web": "npm run e2e -w apps/web",
    "test": "node --test scripts/tests/*.test.mjs"
  },
  "engines": {
    "node": ">=20"
  }
}
